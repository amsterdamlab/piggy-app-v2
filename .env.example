VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Wompi Environment Switch ('sandbox' | 'production')
VITE_WOMPI_ENV=sandbox

# Wompi Sandbox (Pruebas)
VITE_WOMPI_PUB_KEY_TEST=pub_test_XXXX
WOMPI_INTEGRITY_SECRET_TEST=test_integrity_XXXX
WOMPI_EVENTS_SECRET_TEST=test_events_XXXX
WOMPI_PRIVATE_KEY_TEST=prv_test_XXXX

# Wompi Production (Real)
VITE_WOMPI_PUB_KEY_PROD=pub_prod_XXXX
WOMPI_INTEGRITY_SECRET_PROD=prod_integrity_XXXX
WOMPI_EVENTS_SECRET_PROD=prod_events_XXXX
WOMPI_PRIVATE_KEY_PROD=prv_prod_XXXX
